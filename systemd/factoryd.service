[Unit]
Description=AI Code Factory supervisor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/permafactory
Environment=NODE_ENV=production
ExecStart=/usr/bin/env npm run factoryd -- --repo /opt/project
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
