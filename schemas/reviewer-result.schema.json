{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://permafactory.dev/schemas/reviewer-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "status",
    "summary",
    "followups",
    "blockingFindings",
    "recommendedAction"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockingFindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "summary"
        ],
        "properties": {
          "severity": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "summary": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "recommendedAction": {
      "enum": [
        "merge",
        "request_changes",
        "rerun"
      ]
    }
  }
}
