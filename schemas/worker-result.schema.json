{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://permafactory.dev/schemas/worker-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "status",
    "summary",
    "changedFiles",
    "checks",
    "followups",
    "needsReview",
    "needsDecision"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedCommitMessage": {
      "type": "string"
    },
    "notesForReviewer": {
      "type": "string"
    },
    "needsReview": {
      "type": "boolean"
    },
    "needsDecision": {
      "type": "boolean"
    }
  }
}
