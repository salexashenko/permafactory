{
  "name": "permafactory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "factoryctl": "node --import tsx apps/factoryctl/src/main.ts",
    "factoryd": "node --import tsx apps/factoryd/src/main.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
